RELAY_ACCESS_PASSWORD=replace-with-a-strong-password
RELAY_SESSION_SECRET=replace-with-a-long-random-secret
RELAY_PUBLIC_BASE_URL=https://relay.example.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional server-side aliases if you don't want to use NEXT_PUBLIC_* on the server.
SUPABASE_URL=
SUPABASE_ANON_KEY=

